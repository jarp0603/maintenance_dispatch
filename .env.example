# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.

# --- App -------------------------------------------------------------------
NODE_ENV=development
# Base URL of this app, used server-side to build absolute links (e.g. in emails).
APP_BASE_URL=http://localhost:3000
# Public copy of the app URL, safe to expose to the browser.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (Phase 2/3) ---------------------------------------------------
# Project URL and anon key are public by design (protected by Row Level Security).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key bypasses RLS. Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google OAuth / Gmail (Phase 5) -----------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/gmail/oauth/callback
# Gmail search query used to find candidate work-order emails.
GMAIL_SEARCH_QUERY="is:unread label:maintenance-requests"

# --- Calendly (Phase 8) ------------------------------------------------------
# Personal access token (simplest option for a single-operator account).
CALENDLY_PERSONAL_ACCESS_TOKEN=
# Signing key used to verify Calendly webhook signatures.
CALENDLY_WEBHOOK_SIGNING_KEY=
# Organization URI the webhook subscription is scoped to.
CALENDLY_ORGANIZATION_URI=
