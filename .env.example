# ============================================================
# MAINTENANCE DISPATCH — Environment Variables
# Copy to server/.env and fill in real values.
# Never commit real secrets.
# ============================================================

# App
PORT=3001
NODE_ENV=development
JWT_SECRET=your_jwt_secret_change_this
APP_URL=http://localhost:5173

# Admin login (default: admin / admin123)
# Generate new hash: node -e "console.log(require('bcryptjs').hashSync('yourpassword',10))"
ADMIN_USER=admin
ADMIN_PASS_HASH=

# Database — 'sqlite' for local dev, 'mysql' for Bluehost production
DB_TYPE=sqlite
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=maintenance_dispatch
DB_PORT=3306

# Gmail OAuth2
# Create at https://console.cloud.google.com/ → APIs & Services → Credentials
# Required scopes: gmail.readonly, userinfo.email
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3001/api/gmail/callback
GMAIL_USER_EMAIL=juan20643@gmail.com

# Calendly
# API key: https://calendly.com/integrations/api_webhooks
CALENDLY_API_KEY=
CALENDLY_EVENT_URL=
CALENDLY_WEBHOOK_SECRET=

# Google Maps (optional — enables real route directions)
# Enable: Maps JavaScript API + Directions API + Geocoding API
GOOGLE_MAPS_API_KEY=

# Follow-up timing (hours) — overrides DB settings if set
FOLLOWUP_1_HOURS=48
FOLLOWUP_2_HOURS=96
REMINDER_HOURS=24

# ============================================================
# LEGACY NEXT.JS VARS (ignore if using client/server stack)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
