# Maintenance Dispatch API - local placeholder configuration only.
# Copy to server/.env for local development. Never insert production values here.

PORT=3001
NODE_ENV=development
APP_URL=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-value
ADMIN_USER=replace-with-admin-username
ADMIN_PASS_HASH=replace-with-bcrypt-password-hash

# Use SQLite for isolated local development. Railway production uses mysql.
DB_TYPE=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=replace-with-database-user
DB_PASSWORD=replace-with-database-password
DB_NAME=maintenance_dispatch

# Gmail OAuth - optional; leave unconfigured unless testing the integration.
GMAIL_CLIENT_ID=replace-with-google-oauth-client-id
GMAIL_CLIENT_SECRET=replace-with-google-oauth-client-secret
GMAIL_REDIRECT_URI=http://localhost:3001/api/gmail/callback
GMAIL_USER_EMAIL=sender@example.invalid
GMAIL_SEARCH_QUERY=replace-with-gmail-search-query

# Calendly - optional.
CALENDLY_PERSONAL_ACCESS_TOKEN=replace-with-calendly-token
CALENDLY_WEBHOOK_SIGNING_KEY=replace-with-calendly-signing-key
CALENDLY_EVENT_URL=https://calendly.example.invalid/maintenance

# Google Maps - optional. This value belongs on the API server only.
GOOGLE_MAPS_API_KEY=replace-with-google-maps-api-key

# Notification behavior.
FOLLOWUP_DAYS=3
FOLLOWUP_TIME=09:00

# Frontend build variable. It is intentionally public in the compiled browser app.
VITE_API_URL=http://localhost:3001
