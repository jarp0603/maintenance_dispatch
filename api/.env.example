# ===========================================================================
# Maintenance Dispatch — PHP API environment (.env)
# Copy to api/.env and fill in real values. NEVER commit the real .env.
# On Bluehost, place this file OUTSIDE public_html when possible and point to it
# with the APP_ENV_PATH environment variable (see BLUEHOST_DEPLOYMENT.md).
# ===========================================================================

# Environment: 'production' enables Secure cookies + HTTPS assumptions.
APP_ENV=production

# Public URL of the React frontend (used for CORS + scheduling link base).
APP_URL=https://yourdomain.com

# --- Database (Bluehost MySQL) ---------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=youruser_dispatch
DB_USER=youruser_dispatch
DB_PASSWORD=

# --- Mail (optional; uses Bluehost SMTP, no paid service) -------------------
# Leave blank to disable outbound email; the app still works.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=dispatch@yourdomain.com

# --- Gmail OAuth (optional: import maintenance-request emails) --------------
# Use the PRODUCTION callback URL in Google Cloud Console.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://yourdomain.com/api/gmail/callback

# --- Google Maps (OPTIONAL, BILLABLE) --------------------------------------
# Leaving this blank keeps route distance on the free haversine fallback.
# Enabling Directions API may incur Google charges — do not set without intent.
GOOGLE_MAPS_API_KEY=

# --- Follow-up timing (hours) ----------------------------------------------
FOLLOWUP_1_HOURS=48
FOLLOWUP_2_HOURS=96
REMINDER_HOURS=24
